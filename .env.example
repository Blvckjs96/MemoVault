# MemoVault Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM Backend: "openai" or "ollama"
MEMOVAULT_LLM_BACKEND=ollama

# OpenAI Settings (required if MEMOVAULT_LLM_BACKEND=openai)
# MEMOVAULT_OPENAI_API_KEY=sk-your-api-key-here
# MEMOVAULT_OPENAI_MODEL=gpt-4o-mini
# MEMOVAULT_OPENAI_API_BASE=https://api.openai.com/v1

# Ollama Settings (required if MEMOVAULT_LLM_BACKEND=ollama)
MEMOVAULT_OLLAMA_MODEL=llama3.1:latest
MEMOVAULT_OLLAMA_API_BASE=http://localhost:11434

# LLM Generation Parameters
MEMOVAULT_LLM_TEMPERATURE=0.7
MEMOVAULT_LLM_MAX_TOKENS=4096

# =============================================================================
# Embedder Configuration
# =============================================================================

# Embedder Backend: "openai", "ollama", or "sentence_transformer"
MEMOVAULT_EMBEDDER_BACKEND=ollama

# OpenAI Embedder Settings
# MEMOVAULT_EMBEDDER_OPENAI_MODEL=text-embedding-3-small
# MEMOVAULT_EMBEDDER_OPENAI_DIMS=1536

# Ollama Embedder Settings
MEMOVAULT_EMBEDDER_OLLAMA_MODEL=nomic-embed-text:latest

# Sentence Transformer Settings (fully local, no server needed)
# MEMOVAULT_EMBEDDER_ST_MODEL=all-MiniLM-L6-v2

# =============================================================================
# Memory Configuration
# =============================================================================

# Memory Backend: "simple" (BM25, no vector DB) or "vector" (Qdrant, semantic search)
MEMOVAULT_MEMORY_BACKEND=simple

# =============================================================================
# Vector Database Configuration (Qdrant — only needed if MEMOVAULT_MEMORY_BACKEND=vector)
# =============================================================================

# Qdrant Mode: "local" (embedded, no server) or "server" (Docker/remote)
MEMOVAULT_QDRANT_MODE=local

# Local/Embedded Qdrant path
MEMOVAULT_QDRANT_PATH=./memovault_data/qdrant

# Server Qdrant Settings (if using server mode)
# MEMOVAULT_QDRANT_HOST=localhost
# MEMOVAULT_QDRANT_PORT=6333
# MEMOVAULT_QDRANT_URL=https://your-qdrant-cloud-url
# MEMOVAULT_QDRANT_API_KEY=your-qdrant-api-key

# Qdrant Collection Settings
MEMOVAULT_QDRANT_COLLECTION=memovault_memories
# nomic-embed-text = 768 dims, text-embedding-3-small = 1536 dims
MEMOVAULT_QDRANT_VECTOR_DIM=768

# =============================================================================
# Intelligence Layer Configuration
# =============================================================================

# Auto-score memories on add (true/false)
MEMOVAULT_AUTO_SCORE=true

# Minimum importance score (1-10) to store a memory
MEMOVAULT_IMPORTANCE_THRESHOLD=5

# Optional fast model for scoring/consolidation (leave empty to use main model)
# Ollama: use a smaller model for speed (e.g. qwen2.5-coder:3b)
MEMOVAULT_SCORER_OLLAMA_MODEL=
# OpenAI: use a cheaper model (e.g. gpt-4o-mini)
MEMOVAULT_SCORER_OPENAI_MODEL=

# STM/LTM Settings
MEMOVAULT_LTM_BASE_THRESHOLD=2.0
MEMOVAULT_STM_ENABLED=true
MEMOVAULT_PROMOTION_RECALL_THRESHOLD=3

# =============================================================================
# Storage & API Configuration
# =============================================================================

MEMOVAULT_DATA_DIR=./memovault_data
MEMOVAULT_API_HOST=127.0.0.1
MEMOVAULT_API_PORT=8080

# =============================================================================
# Logging
# =============================================================================

MEMOVAULT_LOG_LEVEL=INFO
